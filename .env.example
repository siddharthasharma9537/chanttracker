# ────────────────────────────── SUPABASE ──────────────────────────────
# Get these from https://app.supabase.com/project/[PROJECT_ID]/settings/api

VITE_SUPABASE_URL=https://neqnfukluaxwgtjjgrfu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_O6pzpR_EmGHBumqrF6nX9A_1Ge2hPpS

# Service role key (backend only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ────────────────────────────── CLOUDFLARE ────────────────────────────
# Get these from https://dash.cloudflare.com/

VITE_CLOUDFLARE_WORKER_URL=https://chanttracker-edge.yourname.workers.dev
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# ────────────────────────── WEB (Next.js) ─────────────────────────────

# Vercel (optional, only if deploying to Vercel)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=your_vercel_project_id

# Analytics (optional)
NEXT_PUBLIC_GA_ID=your_google_analytics_id

# ────────────────────────────── iOS ─────────────────────────────────
# Set in Xcode Build Settings or .xcconfig file

# App ID Prefix (from Apple Developer)
APPLE_TEAM_ID=your_apple_team_id
APPLE_BUNDLE_ID=com.siddharthasharma.chanttracker

# Signing
APPLE_CERTIFICATE_P8=path_to_apple_signing_key.p8
APPLE_CERTIFICATE_P8_PASSWORD=your_p8_password

# ───────────────────────────── ANDROID ──────────────────────────────

# Keystore for Play Store signing
ANDROID_KEYSTORE_PATH=~/.android/chanttracker.keystore
ANDROID_KEYSTORE_PASSWORD=your_keystore_password
ANDROID_KEY_ALIAS=chanttracker
ANDROID_KEY_PASSWORD=your_key_password

# Play Store credentials
PLAY_STORE_JSON=path_to/play_console_service_account.json

# ───────────────────────────── DEV ──────────────────────────────────

NODE_ENV=development
DEBUG=chanttracker:*
